# Windrose Telegram bot configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to git -- it contains secrets.

# --- Required ---
BOT_TOKEN=your-telegram-bot-token-here
ADMIN_CHAT_ID=123456789

# --- Optional ---
# Comma-separated Telegram user IDs who may issue commands (ADR-007)
# ADMIN_CHAT_ID is always implicitly included.
ALLOWED_CHAT_IDS=123456789,987654321

# Who receives player join/leave and server event notifications (ADR-007)
NOTIFY_CHAT_IDS=123456789,987654321

# Player monitor (ADR-008)
# auto | watchdog | polling | off
PLAYER_MONITOR_MODE=auto
LOG_PATH=/home/YOUR_USER/log/windrose.log
POLL_INTERVAL_SECONDS=30

# Log-line regexes -- MUST be verified against a running server (ADR-008)
# Adjust these after checking: journalctl -u windrose | grep -iE '(connect|player|join)'
LOG_PATTERN_CONNECT=Client connected.*?([A-Za-z0-9_\- ]{3,32})$
LOG_PATTERN_DISCONNECT=Client disconnected.*?([A-Za-z0-9_\- ]{3,32})$

# State file path (persists known players across bot restarts -- ADR-008)
STATE_PATH=/home/YOUR_USER/windrose-telegram-bot/state.json
